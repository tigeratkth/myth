# 业务智能体 · 环境变量模板
# 复制为 .env 后填入实际的 API Key；.env 已在 .gitignore 中，不会被提交
#
# 只需填写你打算使用的模型对应的 Key，其他可留空。
# 所有 Key 仅在本地使用，不会上传到任何服务器。

# ============= OpenAI =============
OPENAI_API_KEY=
# 可选：自定义 Base URL（代理/兼容接口）
OPENAI_BASE_URL=

# ============= Anthropic (Claude) =============
ANTHROPIC_API_KEY=

# ============= DeepSeek =============
DEEPSEEK_API_KEY=

# ============= 通义千问 / DashScope =============
DASHSCOPE_API_KEY=

# ============= 其他（自定义） =============
# 自定义 Provider 可按 LiteLLM 规则添加，详见 README
